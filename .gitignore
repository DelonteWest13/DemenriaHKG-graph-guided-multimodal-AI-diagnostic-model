*.ckpt
*.npy
runs/
logs/

# 医学影像与大型数据集 (防止超出 GitHub 100MB 单文件限制)
*.nii
*.nii.gz
*.dcm
data/
dataset/
datasets/
*.csv
*.xlsx

# 环境变量与机密配置
.env

# 操作系统与编辑器生成的隐藏文件
.DS_Store
Thumbs.db
.vscode/